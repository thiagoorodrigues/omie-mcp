# ---- Bridge server ----
PORT=3000
# Optional shared secret. If set, incoming webhooks must present it (see README).
BRIDGE_WEBHOOK_TOKEN=

# ---- Chatwoot (application API) ----
CHATWOOT_URL=https://chatwoot.example.com
CHATWOOT_ACCOUNT_ID=1
# Access token of an agent/agent-bot with API access (Profile > Access Token).
CHATWOOT_API_TOKEN=xxxxxxxxxxxxxxxxxxxx
# The API-channel inbox id that Evolution conversations land in.
CHATWOOT_INBOX_ID=1

# ---- Evolution Go (WhatsApp) ----
EVOLUTION_URL=http://localhost:8080
# Global API key (sent as the `apikey` header). Configurable name below.
EVOLUTION_API_KEY=xxxxxxxxxxxxxxxxxxxx
# Per-instance token (sent as the `token` header). Evolution Go resolves the
# instance from this token on /send/* calls.
EVOLUTION_INSTANCE_TOKEN=
# Header names — override only if your Evolution Go build differs.
EVOLUTION_API_KEY_HEADER=apikey
EVOLUTION_INSTANCE_TOKEN_HEADER=token

# ---- Behaviour ----
# Normalize Brazilian numbers (insert the 9th mobile digit when missing).
NORMALIZE_BR_NUMBERS=true
# Dedupe window (ms) to drop duplicate deliveries / echoes.
DEDUPE_TTL_MS=300000
